# Composer
/vendor/
composer.lock

# PrestaShop build artifacts
/qameraai-*.zip

# PrestaShop install-time generated locale-specific config (regenerated
# per locale at every install; not source of truth).
/config_*.xml

# IDE
.idea/
.vscode/
*.iml

# OS
.DS_Store
Thumbs.db

# Local config / secrets
.env
.env.*
!.env.example
docker/.env

# Test / coverage
.phpunit.result.cache
/coverage/
/.phpunit.cache/

# Operator smoke runners — by convention they live untracked under tests/Smoke/
# (see CLAUDE.md "Credentials for smoke testing"). Bootstrap PrestaShop, call
# live qamera.ai endpoints with BO-stored credentials — never CI.
/tests/Smoke/

# PHPStan: PrestaShop source clone used by CI for core resolution
/.ps-src/

# Claude Code worktrees (created by EnterWorktree native tool)
/.claude/worktrees/

# Logs
*.log

# Ad-hoc smoke-test request body scratch file written by the PowerShell
# smoke runner (used for `curl --data-binary @<file>`); never tracked.
/.smoke-body.json

# Transient fetch artifact written by the /review-fix skill while it
# triages PR review comments; never tracked.
/pr-comments.json
