{
  "name": "200iqlabs/qameraai",
  "description": "Qamera AI integration for PrestaShop — AI-powered product photography",
  "type": "prestashop-module",
  "license": "MIT",
  "authors": [
    {
      "name": "200iq Labs",
      "email": "hello@200iqlabs.io",
      "homepage": "https://qamera.ai"
    }
  ],
  "require": {
    "php": ">=8.1",
    "ext-json": "*",
    "ext-openssl": "*",
    "guzzlehttp/guzzle": "^7.0",
    "ramsey/uuid": "^4.0"
  },
  "require-dev": {
    "phpunit/phpunit": "^10.0",
    "phpstan/phpstan": "^1.10",
    "squizlabs/php_codesniffer": "^3.7",
    "prestashop/php-dev-tools": "^4.0"
  },
  "autoload": {
    "psr-4": {
      "QameraAi\\Module\\": "src/"
    },
    "classmap": [
      "qameraai.php"
    ]
  },
  "autoload-dev": {
    "psr-4": {
      "QameraAi\\Module\\Tests\\": "tests/"
    }
  },
  "config": {
    "preferred-install": "dist",
    "prepend-autoloader": false,
    "sort-packages": true,
    "platform": {
      "php": "8.1"
    }
  },
  "scripts": {
    "lint": "phpcs --standard=PSR12 src/ tests/",
    "lint:fix": "phpcbf --standard=PSR12 src/ tests/",
    "analyse": "phpstan analyse src/ --level=5",
    "test": "phpunit"
  }
}
