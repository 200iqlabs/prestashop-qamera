<?xml version="1.0" encoding="UTF-8"?>
<xliff xmlns="urn:oasis:names:tc:xliff:document:1.2" version="1.2">
  <file source-language="en" target-language="pl" datatype="plaintext" original="Modules.Qameraai.Admin">
    <body>
      <trans-unit id="qameraai.module.name">
        <source>Qamera AI</source>
        <target>Qamera AI</target>
      </trans-unit>
      <trans-unit id="qameraai.module.description">
        <source>AI-powered product photography: packshots and full sessions from your store products.</source>
        <target>Fotografia produktowa oparta na AI: packshoty i pełne sesje z produktów Twojego sklepu.</target>
      </trans-unit>
      <trans-unit id="qameraai.configuration.title">
        <source>Qamera AI configuration</source>
        <target>Konfiguracja Qamera AI</target>
      </trans-unit>
      <trans-unit id="qameraai.configuration.api_base_url">
        <source>API base URL</source>
        <target>Bazowy URL API</target>
      </trans-unit>
      <trans-unit id="qameraai.configuration.api_key">
        <source>API key</source>
        <target>Klucz API</target>
      </trans-unit>
      <trans-unit id="qameraai.configuration.webhook_secret">
        <source>Webhook secret</source>
        <target>Sekret webhooka</target>
      </trans-unit>
      <trans-unit id="qameraai.configuration.auto_register">
        <source>Auto-register new products</source>
        <target>Automatyczna rejestracja nowych produktów</target>
      </trans-unit>
      <trans-unit id="qameraai.configuration.batch_size">
        <source>Sync batch size</source>
        <target>Rozmiar partii synchronizacji</target>
      </trans-unit>
      <trans-unit id="qameraai.configuration.test_connection">
        <source>Test connection</source>
        <target>Testuj połączenie</target>
      </trans-unit>
      <trans-unit id="qameraai.configuration.saved">
        <source>Settings saved.</source>
        <target>Ustawienia zapisane.</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.testing">
        <source>Testing connection…</source>
        <target>Testowanie połączenia…</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.success">
        <source>Connection successful</source>
        <target>Połączenie udane</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.failure">
        <source>Connection failed</source>
        <target>Połączenie nieudane</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.network">
        <source>Network error reaching Qamera AI</source>
        <target>Błąd sieci przy próbie połączenia z Qamera AI</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.fields.accountName">
        <source>Account</source>
        <target>Konto</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.fields.credits">
        <source>Credits</source>
        <target>Kredyty</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.fields.plan">
        <source>Plan</source>
        <target>Plan</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.fields.platform">
        <source>Platform</source>
        <target>Platforma</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.fields.status">
        <source>Status</source>
        <target>Status</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.errors.csrf">
        <source>Invalid CSRF token.</source>
        <target>Nieprawidłowy token CSRF.</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.errors.transport">
        <source>Could not reach Qamera AI. Check your network or the API base URL.</source>
        <target>Nie udało się połączyć z Qamera AI. Sprawdź sieć lub bazowy URL API.</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.errors.auth">
        <source>Authentication failed. Verify the API key and that the installation is active.</source>
        <target>Uwierzytelnianie nie powiodło się. Sprawdź klucz API oraz czy instalacja jest aktywna.</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.errors.notConfigured">
        <source>Qamera AI API key is not configured. Save your credentials first.</source>
        <target>Klucz API Qamera AI nie został skonfigurowany. Zapisz najpierw dane logowania.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.missing_signature">
        <source>Missing X-Qamera-Signature header.</source>
        <target>Brak nagłówka X-Qamera-Signature.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.malformed_signature">
        <source>Malformed X-Qamera-Signature header.</source>
        <target>Nieprawidłowy nagłówek X-Qamera-Signature.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.signature_mismatch">
        <source>Signature does not match the configured webhook secret.</source>
        <target>Podpis nie zgadza się ze skonfigurowanym sekretem webhooka.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.replay_window">
        <source>Delivery timestamp is outside the replay window.</source>
        <target>Znacznik czasu dostawy jest poza dopuszczalnym oknem replay.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.missing_delivery_id">
        <source>Missing X-Qamera-Delivery-Id header.</source>
        <target>Brak nagłówka X-Qamera-Delivery-Id.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.delivery_id_mismatch">
        <source>Body delivery_id does not match the X-Qamera-Delivery-Id header.</source>
        <target>Pole delivery_id w treści nie zgadza się z nagłówkiem X-Qamera-Delivery-Id.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.malformed_body">
        <source>Webhook body is not a valid JSON object.</source>
        <target>Treść webhooka nie jest prawidłowym obiektem JSON.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.malformed_event_type">
        <source>Webhook event_type is missing or has an unsupported format.</source>
        <target>Pole event_type webhooka jest puste lub ma niedozwolony format.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.empty_body">
        <source>Webhook body is empty.</source>
        <target>Treść webhooka jest pusta.</target>
      </trans-unit>
      <trans-unit id="webhook.reason.method_not_allowed">
        <source>Webhook endpoint accepts only POST.</source>
        <target>Endpoint webhooka akceptuje wyłącznie metodę POST.</target>
      </trans-unit>
    </body>
  </file>
