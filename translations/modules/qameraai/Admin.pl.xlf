        <target>Testowanie połączenia…</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.success">
        <source>Connection successful</source>
        <target>Połączenie udane</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.failure">
        <source>Connection failed</source>
        <target>Połączenie nieudane</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.network">
        <source>Network error reaching Qamera AI</source>
        <target>Błąd sieci przy próbie połączenia z Qamera AI</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.fields.accountName">
        <source>Account</source>
        <target>Konto</target>
      </trans-unit>
      <trans-unit id="apiClient.testConnection.fields.credits">
