{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
  <div class="card">
    <div class="card-header">
      <h3 class="card-header-title">
        <i class="material-icons">photo_library</i>
        {{ 'Qamera AI — Products'|trans({}, 'Modules.Qameraai.Admin') }}
      </h3>
      <div class="card-header-actions">
        <a href="{{ jobs_url }}" class="btn btn-outline-secondary">
          <i class="material-icons">history</i>
          {{ 'Jobs history'|trans({}, 'Modules.Qameraai.Admin') }}
        </a>
      </div>
    </div>

    <div class="card-body">
      {% if rows is empty %}
        <div class="alert alert-info" role="alert">
          {{ 'No synced products yet. Save a product or enable auto-register in Configuration.'|trans({}, 'Modules.Qameraai.Admin') }}
        </div>
      {% else %}
        <form id="qameraai-products-bulk-form" method="get" action="{{ generate_url }}">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th style="width:32px;">
                  <input type="checkbox" id="qameraai-select-all">
                </th>
                <th>{{ 'Product'|trans({}, 'Modules.Qameraai.Admin') }}</th>
                <th>{{ 'Status'|trans({}, 'Modules.Qameraai.Admin') }}</th>
                <th>{{ 'Last synced'|trans({}, 'Modules.Qameraai.Admin') }}</th>
                <th style="width:160px;">{{ 'Action'|trans({}, 'Modules.Qameraai.Admin') }}</th>
              </tr>
            </thead>
            <tbody>
              {% for row in rows %}
                <tr>
                  <td>
                    {% if row.can_generate %}
                      <input type="checkbox"
                             class="qameraai-row-select"
                             name="products[]"
                             value="{{ row.id_product }}">
                    {% else %}
                      <input type="checkbox" disabled
                             title="{{ 'Sync this product first'|trans({}, 'Modules.Qameraai.Admin') }}">
                    {% endif %}
                  </td>
                  <td>
                    <strong>{{ row.name }}</strong>
                    <br>
                    <small class="text-muted">#{{ row.id_product }} · {{ row.product_ref }}</small>
                  </td>
                  <td>
                    <span class="qameraai-badge qameraai-badge-{{ row.status|default('pending') }}">
                      {{ row.status|default('pending')|trans({}, 'Modules.Qameraai.Admin') }}
                    </span>
                  </td>
                  <td>
                    {{ row.last_synced_at|default('—') }}
                  </td>
                  <td>
                    {% if row.can_generate %}
                      <a href="{{ generate_url }}?products={{ row.id_product }}"
                         class="btn btn-primary btn-sm">
                        <i class="material-icons">auto_fix_high</i>
                        {{ 'Generate'|trans({}, 'Modules.Qameraai.Admin') }}
                      </a>
                    {% else %}
                      <button type="button"
                              class="btn btn-secondary btn-sm"
                              disabled
                              title="{{ 'Sync this product first'|trans({}, 'Modules.Qameraai.Admin') }}">
                        <i class="material-icons">block</i>
                        {{ 'Generate'|trans({}, 'Modules.Qameraai.Admin') }}
                      </button>
                    {% endif %}
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>

          <div class="d-flex justify-content-between align-items-center">
            <div>
              <button type="submit" class="btn btn-primary" id="qameraai-bulk-generate" disabled>
                <i class="material-icons">auto_fix_high</i>
                {{ 'Generate selected'|trans({}, 'Modules.Qameraai.Admin') }}
                (<span id="qameraai-bulk-count">0</span>)
              </button>
            </div>
            <div>
              {% if total_pages > 1 %}
                <nav>
                  <ul class="pagination mb-0">
                    {% for p in 1..total_pages %}
                      <li class="page-item {% if p == page %}active{% endif %}">
                        <a class="page-link" href="?page={{ p }}">{{ p }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </nav>
              {% endif %}
            </div>
          </div>
        </form>
      {% endif %}
    </div>
  </div>

  <script>
    (function () {
      var form = document.getElementById('qameraai-products-bulk-form');
      if (!form) { return; }
      var selectAll = document.getElementById('qameraai-select-all');
      var rowChecks = form.querySelectorAll('.qameraai-row-select');
      var bulkBtn = document.getElementById('qameraai-bulk-generate');
      var counter = document.getElementById('qameraai-bulk-count');

      function refresh() {
        var n = 0;
        rowChecks.forEach(function (cb) { if (cb.checked) { n++; } });
        counter.textContent = String(n);
        bulkBtn.disabled = n === 0;
      }

      selectAll.addEventListener('change', function () {
        rowChecks.forEach(function (cb) { cb.checked = selectAll.checked; });
        refresh();
      });
      rowChecks.forEach(function (cb) {
        cb.addEventListener('change', refresh);
      });
      refresh();
    })();
  </script>
{% endblock %}
