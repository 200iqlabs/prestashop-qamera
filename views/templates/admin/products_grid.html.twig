{% extends '@PrestaShop/Admin/layout.html.twig' %}

{% block content %}
  <div class="card">
    <div class="card-header">
      <h3 class="card-header-title">
        <i class="material-icons">photo_library</i>
        {{ 'Qamera AI — Products'|trans({}, 'Modules.Qameraai.Admin') }}
      </h3>
      <div class="card-header-actions">
        <a href="{{ jobs_url }}" class="btn btn-outline-secondary">
          <i class="material-icons">history</i>
          {{ 'Jobs history'|trans({}, 'Modules.Qameraai.Admin') }}
        </a>
      </div>
    </div>

    <div class="card-body">
      {% if rows is empty %}
        <div class="alert alert-info" role="alert">
          {{ 'No synced products yet. Save a product or enable auto-register in Configuration.'|trans({}, 'Modules.Qameraai.Admin') }}
        </div>
      {% else %}
        <form id="qameraai-products-bulk-form" method="get" action="{{ generate_url }}">
          <table class="table table-bordered table-hover">
            <thead>
              <tr>
                <th style="width:32px;">
                  <input type="checkbox" id="qameraai-select-all">
                </th>
                <th>{{ 'Product'|trans({}, 'Modules.Qameraai.Admin') }}</th>
                <th>{{ 'Sync status'|trans({}, 'Modules.Qameraai.Admin') }}</th>
                <th>{{ 'Analysis'|trans({}, 'Modules.Qameraai.Admin') }}</th>
                <th>{{ 'Last synced'|trans({}, 'Modules.Qameraai.Admin') }}</th>
                <th style="width:200px;">{{ 'Action'|trans({}, 'Modules.Qameraai.Admin') }}</th>
              </tr>
            </thead>
            <tbody>
              {% for row in rows %}
                {% set analysis_status_key = row.analysis_status|default('null') %}
                {% set badge_meta = {
                  'described': {'class': 'badge-success', 'label': 'Ready'|trans({}, 'Modules.Qameraai.Admin'), 'icon': '✓'},
                  'partial':   {'class': 'badge-warning', 'label': 'Partial'|trans({}, 'Modules.Qameraai.Admin'), 'icon': '◐'},
                  'processing':{'class': 'badge-info',    'label': 'Processing'|trans({}, 'Modules.Qameraai.Admin'), 'icon': '🔄'},
                  'error':     {'class': 'badge-danger',  'label': 'Error'|trans({}, 'Modules.Qameraai.Admin'),   'icon': '⚠'},
                  'pending':   {'class': 'badge-secondary','label': 'Pending'|trans({}, 'Modules.Qameraai.Admin'),'icon': '⏳'},
                  'null':      {'class': 'badge-secondary','label': 'Pending'|trans({}, 'Modules.Qameraai.Admin'),'icon': '⏳'},
                }[analysis_status_key] %}
                <tr>
                  <td>
                    {% if row.can_generate %}
                      <input type="checkbox"
                             class="qameraai-row-select"
                             name="products[]"
                             value="{{ row.id_product }}"
                             data-id-link="{{ row.id_link }}">
                    {% else %}
                      <input type="checkbox" disabled
                             class="qameraai-row-select"
                             data-id-link="{{ row.id_link }}"
                             title="{{ row.disabled_hint|default('Sync this product first')|trans({}, 'Modules.Qameraai.Admin') }}">
                    {% endif %}
                  </td>
                  <td>
                    <strong>{{ row.name }}</strong>
                    <br>
                    <small class="text-muted">#{{ row.id_product }} · {{ row.product_ref }}</small>
                  </td>
                  <td>
                    <span class="qameraai-badge qameraai-badge-{{ row.status|default('pending') }}">
                      {{ row.status|default('pending')|trans({}, 'Modules.Qameraai.Admin') }}
                    </span>
                  </td>
                  <td>
                    <span class="badge {{ badge_meta.class }}"
                          data-id-link="{{ row.id_link }}"
                          data-analysis-status="{{ analysis_status_key }}"
                          {% if row.analysis_refreshed_at %}title="{{ 'Refreshed at'|trans({}, 'Modules.Qameraai.Admin') }} {{ row.analysis_refreshed_at }}"{% endif %}>
                      {{ badge_meta.icon }} {{ badge_meta.label }}{% if row.analysis_total_count and row.analysis_total_count > 1 %} ({{ row.analysis_described_count|default(0) }} of {{ row.analysis_total_count }}){% endif %}
                    </span>
                  </td>
                  <td>
                    {{ row.last_synced_at|default('—') }}
                  </td>
                  <td>
                    {% if row.can_generate %}
                      <a href="{{ generate_url }}?products={{ row.id_product }}"
                         class="btn btn-primary btn-sm js-qameraai-generate"
                         data-id-link="{{ row.id_link }}">
                        <i class="material-icons">auto_fix_high</i>
                        {{ 'Generate'|trans({}, 'Modules.Qameraai.Admin') }}
                      </a>
                    {% else %}
                      <button type="button"
                              class="btn btn-secondary btn-sm js-qameraai-generate"
                              disabled
                              data-id-link="{{ row.id_link }}"
                              title="{{ row.disabled_hint|default('Sync this product first')|trans({}, 'Modules.Qameraai.Admin') }}">
                        <i class="material-icons">block</i>
                        {{ 'Generate'|trans({}, 'Modules.Qameraai.Admin') }}
                      </button>
                    {% endif %}
                    <button type="button"
                            class="btn btn-outline-secondary btn-sm js-qameraai-refresh-analysis"
                            data-id-link="{{ row.id_link }}"
                            title="{{ 'Refresh analysis status'|trans({}, 'Modules.Qameraai.Admin') }}">
                      <i class="material-icons">refresh</i>
                    </button>
                  </td>
                </tr>
              {% endfor %}
            </tbody>
          </table>

          <div class="d-flex justify-content-between align-items-center">
            <div>
              <button type="submit" class="btn btn-primary" id="qameraai-bulk-generate" disabled>
                <i class="material-icons">auto_fix_high</i>
                {{ 'Generate selected'|trans({}, 'Modules.Qameraai.Admin') }}
                (<span id="qameraai-bulk-count">0</span>)
              </button>
            </div>
            <div>
              {% if total_pages > 1 %}
                <nav>
                  <ul class="pagination mb-0">
                    {% for p in 1..total_pages %}
                      <li class="page-item {% if p == page %}active{% endif %}">
                        <a class="page-link" href="?page={{ p }}">{{ p }}</a>
                      </li>
                    {% endfor %}
                  </ul>
                </nav>
              {% endif %}
            </div>
          </div>
        </form>
      {% endif %}
    </div>
  </div>

  <script>
    window.QameraAiProductsGrid = {
      statusUrlTemplate: {{ status_url_template|json_encode|raw }}
    };
  </script>
  <script src="{{ js_asset_url }}"></script>
{% endblock %}
